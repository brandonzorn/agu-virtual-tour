       <item value="startscene" name="Start scene of the tour"/>
       <item value="webpage" name="Specific webpage"/>
      </select>
      <label id="firstscenedescription" conditionalParam="homeAction" customize="false" conditionalValues="firstscene" uiPreview="false" name="tr:The scene described as the first one in the project."/>
      <label id="startscenedescription" conditionalParam="homeAction" customize="false" conditionalValues="startscene" uiPreview="false" name="tr:The scene the user saw first. It can be different of the first scene, if the user used a deep link to enter the tour."/>
      <string id="webpageurl" conditionalParam="homeAction" staticmessageid="" customize="false" conditionalValues="webpage" default="" type="url" needTranslation="true" uiPreview="false" name="tr:Webpage URL"/>
     </feature>
     <feature id="fullscreen" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="True" uiPreview="false" guiIcon="btn_enter_fs.png" name="tr:Fullscreen">
      <string id="openFsTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Enter fullscreen" needTranslation="true" uiPreview="false" name="tr:Enter fullscreen tooltip"/>
      <string id="closeFsTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Exit fullscreen" needTranslation="true" uiPreview="false" name="tr:Exit fullscreen tooltip"/>
