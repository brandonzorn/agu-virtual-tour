  <build imgJpegQuality="12" websiteWithCredentials="false" mobilesTour="true" useMobileScale="true" lang="ru,en" displayErrors="true" useMultiResolution="true" htmlTemplate="fullpage.html" filename="agu-tour-01" encryptConfig="false" desktopTour="true" flashTour="false" html5Tour="true" exportComments="true" baseDir="C:/Users/bzorn/Pictures/agu-tour-01" iBookTour="false"/>
  <plugins>
   <plugin id="gyroscope" name="Gyroscope">
    <param id="warningMess" customize="false" uiPreview="false" name="tr:The gyroscope plugin allows user to control the view by moving its mobile or tablet device."/>
    <param id="startActivated" description="tr:Start the tour with gyroscope activated" customize="false" default="false" uiPreview="false" name="tr:Start activated"/>
    <param id="deviceSelector" customize="false" default="all" uiPreview="false" name="tr:Devices concerned">
     <item value="all" name="All tablets and mobiles devices"/>
     <item value="tablet" name="Only tablets"/>
     <item value="mobile" name="Only mobiles"/>
     <item value="ios" name="Only iOS devices (iPhone, iPad, iPod)"/>
     <item value="android" name="Only Android devices"/>
    </param>
    <param id="noCamRoll" customize="false" default="false" uiPreview="false" name="tr:Deactivate the roll axis"/>
   </plugin>
   <plugin id="controlBar_i" name="iControl Bar">
    <param id="position_group" customize="false" uiPreview="false" name="tr:Position">
     <position id="position" defaultOrientation="horizontal" y="10" customize="false" needOrientation="true" default="bottom" availableValues="topleft,topright,bottomleft,bottomright,bottom,top,left,right" xUnit="pixel" uiPreview="false" x="0" xUnits="pixel" yUnits="pixel" yUnit="pixel" name="tr:Position"/>
    </param>
    <param id="display" customize="false" uiPreview="false" name="tr:Display">
     <color id="color" allowDynamicSource="false" defaultAlpha="1" customize="false" default="#9b9b9b" needAlpha="true" source="customColor" uiPreview="false" name="tr:Background color"/>
     <bool id="tooltips" customize="false" default="false" uiPreview="false" name="tr:Show tooltips"/>
    </param>
    <param id="controls" customize="false" uiPreview="false" name="tr:Available controls">
     <feature id="videoplaypause" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="False" uiPreview="false" guiIcon="btn_start_videoplayer.png" name="tr:Play/Pause a panoramic video">
      <string id="playVideoTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Play" needTranslation="true" uiPreview="false" name="tr:Play video tooltip"/>
      <string id="pauseVideoTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Pause" needTranslation="true" uiPreview="false" name="tr:Pause video tooltip"/>
     </feature>
     <feature id="prevnext" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="False" uiPreview="false" guiIcon="btn_next_scene.png" name="tr:Previous/Next panorama">
      <string id="prevSceneTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Previous panorama" needTranslation="true" uiPreview="false" name="tr:Previous panorama tooltip"/>
      <string id="nextSceneTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Next panorama" needTranslation="true" uiPreview="false" name="tr:Next panorama tooltip"/>
      <select id="prevNextAction" customize="false" default="pano" uiPreview="false" name="tr:Action triggered">
       <item value="pano" name="Go to previous or next panorama"/>
       <item value="group" name="Go to previous or next group"/>
      </select>
     </feature>
     <feature id="zoom" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="True" uiPreview="false" guiIcon="btn_zoom_in.png" name="tr:Zoom">
      <string id="zoomInTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Zoom in" needTranslation="true" uiPreview="false" name="tr:Zoom in tooltip"/>
      <string id="zoomOutTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Zoom out" needTranslation="true" uiPreview="false" name="tr:Zoom out tooltip"/>
     </feature>
     <feature id="horizontalnavigation" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="True" uiPreview="false" guiIcon="btn_move_left.png" name="tr:Move horizontally">
      <string id="moveLeftTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Move left" needTranslation="true" uiPreview="false" name="tr:Move left tooltip"/>
      <string id="moveRightTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Move right" needTranslation="true" uiPreview="false" name="tr:Move right tooltip"/>
     </feature>
     <feature id="verticalnavigation" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="True" uiPreview="false" guiIcon="btn_move_up.png" name="tr:Move vertically">
      <string id="moveUpTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Move up" needTranslation="true" uiPreview="false" name="tr:Move up tooltip"/>
      <string id="moveDownTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Move down" needTranslation="true" uiPreview="false" name="tr:Move down tooltip"/>
     </feature>
     <feature id="home" customize="false" forceEnabled="False" crop="0|0|60|60" enabled="False" uiPreview="false" guiIcon="btn_home.png" name="tr:Home">
      <string id="homeTip" conditionalParam="tooltips" staticmessageid="" customize="false" conditionalValues="true" default="Home" needTranslation="true" uiPreview="false" name="tr:Home tooltip"/>
      <select id="homeAction" description="tr:Where does the home button go back" customize="false" default="currentpanoview" uiPreview="false" name="tr:Back to">
       <item value="currentpanoview" name="Default view of current scene"/>
