      <dimension id="flyingheight" conditionalParam="flyonclick" minimum="0" customize="false" conditionalValues="true" default="0" maximum="9999" needAutomatic="false" uiPreview="false" currentUnit="pixel" name="Maximized height" availableUnits="pixel"/>
     </group>
