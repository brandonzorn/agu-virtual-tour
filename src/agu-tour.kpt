  <plugins>
   <plugin id="controlBar_i" name="iControl Bar">
    <param id="position_group" uiPreview="false" customize="false" name="tr:Position">
     <position yUnit="pixel" id="position" defaultOrientation="horizontal" uiPreview="false" customize="false" availableValues="topleft,topright,bottomleft,bottomright,bottom,top,left,right" y="10" xUnits="pixel" default="bottom" needOrientation="true" x="0" xUnit="pixel" name="tr:Position" yUnits="pixel"/>
    </param>
    <param id="display" uiPreview="false" customize="false" name="tr:Display">
     <color source="customColor" id="color" needAlpha="true" defaultAlpha="1" uiPreview="false" customize="false" default="#787878" allowDynamicSource="false" name="tr:Background color"/>
     <bool id="tooltips" uiPreview="false" customize="false" default="false" name="tr:Show tooltips"/>
    </param>
    <param id="controls" uiPreview="false" customize="false" name="tr:Available controls">
     <feature enabled="False" guiIcon="btn_start_videoplayer.png" id="videoplaypause" forceEnabled="False" uiPreview="false" customize="false" crop="0|0|60|60" name="tr:Play/Pause a panoramic video">
      <string id="playVideoTip" uiPreview="false" customize="false" conditionalValues="true" conditionalParam="tooltips" default="Play" needTranslation="true" staticmessageid="" name="tr:Play video tooltip"/>
      <string id="pauseVideoTip" uiPreview="false" customize="false" conditionalValues="true" conditionalParam="tooltips" default="Pause" needTranslation="true" staticmessageid="" name="tr:Pause video tooltip"/>
     </feature>
     <feature enabled="True" guiIcon="btn_next_scene.png" id="prevnext" forceEnabled="False" uiPreview="false" customize="false" crop="0|0|60|60" name="tr:Previous/Next panorama">
      <string id="prevSceneTip" uiPreview="false" customize="false" conditionalValues="true" conditionalParam="tooltips" default="Previous panorama" needTranslation="true" staticmessageid="" name="tr:Previous panorama tooltip"/>
      <string id="nextSceneTip" uiPreview="false" customize="false" conditionalValues="true" conditionalParam="tooltips" default="Next panorama" needTranslation="true" staticmessageid="" name="tr:Next panorama tooltip"/>
