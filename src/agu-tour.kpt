   <presetAction id="user_defaultpolygon0" objectId="0" spotType="polygon" timestamp="0" type="actionpolygon" isDefault="True" locked="False">
    <description description="tr:This is the default preset for polygon hotspots" previewFile=":/UI/spotpolygonpreview.png" name="Default Polygon Spot Style"/>
    <display type="polygon">
     <select id="displayedwhen" customize="false" default="always" uiPreview="false" name="Polygon display">
      <item value="always" name="Always"/>
      <item value="onhover" name="On hover"/>
      <item value="never" name="Never"/>
     </select>
     <color id="bordercolor" allowDynamicSource="false" defaultAlpha="1" customize="false" default="#ffffff" needAlpha="true" source="customColor" uiPreview="false" name="Border color"/>
     <dimension id="borderwidth" minimum="0" customize="false" default="1" maximum="9999" needAutomatic="false" uiPreview="false" currentUnit="pixel" name="Border width" availableUnits="pixel"/>
     <color id="fillcolor" allowDynamicSource="false" defaultAlpha="0.4" customize="false" default="#ffffff" needAlpha="true" source="customColor" uiPreview="false" name="Fill color"/>
     <group id="displayedWhenAlwaysGrp" conditionalParam="displayedwhen" customize="false" conditionalValues="always" uiPreview="false" name="Display options on hover state">
      <bool id="alwayshoverstate" customize="false" default="false" uiPreview="false" name="Change display on hover"/>
