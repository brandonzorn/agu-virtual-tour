    <display type="point">
     <bool uiPreview="false" id="fileorlib" name="Use icon from library" default="true" customize="false"/>
     <filechooser allowRemote="true" uiPreview="false" conditionalParam="fileorlib" allowEmpty="false" id="icon" name="Icon file" conditionalValues="false" default="" customize="false" filters="images,flash"/>
     <spoticonchooser uiPreview="false" conditionalParam="fileorlib" id="iconChooser" name="Icon" conditionalValues="true" allowSequences="true" default="theme02|tr:Direction|sequence" customize="false"/>
     <row uiPreview="false" conditionalParam="fileorlib" id="rowcolor" conditionalValues="true" customize="false">
      <bool uiPreview="false" id="customcolor" name="Custom color" default="true" customize="false"/>
      <color uiPreview="false" conditionalParam="customcolor" id="iconcolor" name="Color" conditionalValues="true" source="currentProjectForeground" needAlpha="true" allowDynamicSource="false" default="#fdc400" customize="false" defaultAlpha="1"/>
     </row>
     <size uiPreview="false" id="size" name="Size" needKeepRatio="false" customize="false">
      <dimension uiPreview="false" id="width" name="Width" maximum="999" availableUnits="pixel" needAutomatic="false" currentUnit="pixel" default="0" customize="false" minimum="0"/>
      <dimension uiPreview="false" id="height" name="Height" maximum="999" availableUnits="pixel" needAutomatic="false" currentUnit="pixel" default="0" customize="false" minimum="0"/>
     </size>
     <advanced uiPreview="false" id="advancedGrp" customize="false">
      <bool uiPreview="false" id="zoom" name="Change size according to zoom level" default="true" customize="false"/>
      <bool uiPreview="false" id="alphaonhover" name="Change transparency on over" default="true" customize="false"/>
      <bool uiPreview="false" id="scaleonhover" name="Scale on over" default="true" customize="false"/>
      <number uiPreview="false" id="rotationAngle" name="Rotation angle" maximum="360" suffix=" °" default="270" customize="false" minimum="0"/>
      <select uiPreview="false" id="anchor" name="Anchor position" default="center" customize="false">
       <item name="Center" value="center"/>
       <item name="Bottom" value="bottom"/>
      </select>
     </advanced>
    </display>
    <display type="common" flags="haspermanenttooltip">
     <bool uiPreview="false" id="pauserotationonhover" name="Pause autorotation on hover" default="false" customize="false"/>
     <string uiPreview="false" id="tooltipTemplate" name="Tooltip text or placeholder" needTranslation="true" staticmessageid="" default="" customize="false" description="Enter a tooltip text which will be assigned to all spots with that style.&#xa;And/or use a placeholder&#xa;- %p for the target panorama or group name&#xa;- %d for the target panorama or group description&#xa;- %DISTANCEINMETERS% for the distance in meters between the scene and the spot target scene or group&#xa;- %DISTANCEINKILOMETERS% for the distance in kilometers between the scene and the spot target scene or group&#xa;- %DISTANCEINMILES% for the distance in miles between the scene and the spot target scene or group&#xa;- %DISTANCEINYARDS% for the distance in yards between the scene and the spot target scene or group&#xa;- %DISTANCEINFEET% for the distance in feet between the scene and the spot target scene or group"/>
     <select uiPreview="false" id="permanentTooltipDesktop" name="Tooltip rule for desktop" default="tooltipdesktoponhover" customize="false">
      <item name="On hover" value="tooltipdesktoponhover"/>
      <item name="Permanent" value="tooltipdesktoppermanent"/>
     </select>
     <select uiPreview="false" id="permanentTooltipDevices" name="Tooltip rule for tablet/mobile devices" default="tooltipdevicesnever" customize="false">
      <item name="Never" value="tooltipdevicesnever"/>
      <item name="Permanent" value="tooltipdevicespermanent"/>
     </select>
     <select uiPreview="false" id="permanentTooltipVR" name="Tooltip rule for VR mode" default="tooltipvrnever" customize="false">
      <item name="Never" value="tooltipvrnever"/>
      <item name="Permanent" value="tooltipvrpermanent"/>
     </select>
    </display>
    <action id="object" name="Go to a panorama or a group" internal="0" category="basic" sourceId="-1" targetId="-1" startFov="0" customTargetView="False" startPitch="0" startYaw="0" actionChooserRef="" type="Object" locked="False" depends="" contentTemplate="" description="Load a specific panorama or the first panorama of a specific group." callTemplate="loadpanoramaactioncall.tmpl">
     <select uiPreview="false" id="sourcetransition" name="Source transition" default="none" customize="true">
      <item name="None" value="none"/>
      <item name="Look to the spot" value="looktospot"/>
      <item name="Zoom in on the spot" value="zoominonspot"/>
      <item name="Zoom in a little bit on the spot" value="zoominonspotless"/>
      <item name="Zoom in on the spot in a planar panorama" value="zoominonspotplanar"/>
      <item name="Zoom in to minimum Fov" value="transitionzoomto"/>
      <item name="Zoom out" value="zoomoutonpanorama"/>
     </select>
     <select uiPreview="false" id="targettransition" name="Target transition" default="loadspotview" customize="true">
      <item name="None" value="none"/>
      <item name="Custom view to panorama view" value="spotviewtopanoview"/>
      <item name="Load custom view" value="loadspotview"/>
      <item name="Load panorama view" value="loadpanoview"/>
      <item name="Move from custom view to panorama view" value="movespotviewtopanoview"/>
      <item name="Move to custom view" value="movespotview"/>
      <item name="Panorama view to custom view" value="panoviewtospotview"/>
      <item name="Zoom out then move to custom view" value="zoomoutandincustomview"/>
     </select>
    </action>
