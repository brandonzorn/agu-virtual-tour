      <dimension id="borderwidthhover" conditionalParam="alwayshoverstate" minimum="0" customize="false" conditionalValues="true" default="4" maximum="9999" needAutomatic="false" uiPreview="false" currentUnit="pixel" name="Border width on hover" availableUnits="pixel"/>
      <color id="fillcolorhover" conditionalParam="alwayshoverstate" allowDynamicSource="false" defaultAlpha="0.6" customize="false" conditionalValues="true" default="#ffffff" needAlpha="true" source="customColor" uiPreview="false" name="Fill color on hover"/>
     </group>
    </display>
    <display type="common">
     <bool id="pauserotationonhover" customize="false" default="false" uiPreview="false" name="Pause autorotation on hover"/>
     <string id="tooltipTemplate" description="Enter a tooltip text which will be assigned to all spots with that style.&#xa;And/or use a placeholder&#xa;- %p for the target panorama or group name&#xa;- %d for the target panorama or group description&#xa;- %DISTANCEINMETERS% for the distance in meters between the scene and the spot target scene or group&#xa;- %DISTANCEINKILOMETERS% for the distance in kilometers between the scene and the spot target scene or group&#xa;- %DISTANCEINMILES% for the distance in miles between the scene and the spot target scene or group&#xa;- %DISTANCEINYARDS% for the distance in yards between the scene and the spot target scene or group&#xa;- %DISTANCEINFEET% for the distance in feet between the scene and the spot target scene or group" staticmessageid="" customize="false" default="" needTranslation="true" uiPreview="false" name="Tooltip text or placeholder"/>
    </display>
    <action id="object" callTemplate="loadpanoramaactioncall.tmpl" targetId="-1" description="Load a specific panorama or the first panorama of a specific group." startPitch="0" startFov="0" customTargetView="False" startYaw="0" type="Object" contentTemplate="" depends="" internal="0" category="basic" actionChooserRef="" locked="False" sourceId="-1" name="Go to a panorama or a group">
     <select id="sourcetransition" customize="true" default="none" uiPreview="false" name="Source transition">
      <item value="none" name="None"/>
      <item value="looktospot" name="Look to the spot"/>
      <item value="zoominonspot" name="Zoom in on the spot"/>
      <item value="zoominonspotless" name="Zoom in a little bit on the spot"/>
      <item value="zoominonspotplanar" name="Zoom in on the spot in a planar panorama"/>
      <item value="transitionzoomto" name="Zoom in to minimum Fov"/>
      <item value="zoomoutonpanorama" name="Zoom out"/>
     </select>
     <select id="targettransition" customize="true" default="loadspotview" uiPreview="false" name="Target transition">
      <item value="none" name="None"/>
      <item value="spotviewtopanoview" name="Custom view to panorama view"/>
      <item value="loadspotview" name="Load custom view"/>
      <item value="loadpanoview" name="Load panorama view"/>
      <item value="movespotviewtopanoview" name="Move from custom view to panorama view"/>
      <item value="movespotview" name="Move to custom view"/>
      <item value="panoviewtospotview" name="Panorama view to custom view"/>
      <item value="zoomoutandincustomview" name="Zoom out then move to custom view"/>
     </select>
    </action>
   </presetAction>
   <presetAction id="user_defaultsound0" objectId="0" spotType="sound" timestamp="0" type="actionsound" isDefault="True" locked="False">
    <description description="tr:This is the default preset for sound hotspots" previewFile=":/UI/spotsoundpreview.png" name="Default Sound Spot Style"/>
    <display type="sound">
     <bool id="endless" customize="false" default="true" uiPreview="false" name="Endless sound"/>
     <number id="loops" conditionalParam="endless" minimum="1" customize="false" conditionalValues="false" default="1" maximum="9999" uiPreview="false" suffix="" name="Number of loops"/>
